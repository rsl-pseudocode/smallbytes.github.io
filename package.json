    "vue": "^3.4.21",
    "vuetify": "^3.5.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.21.0",
    "gh-pages": "^6.1.1",
    "sass": "^1.71.1",
    "typescript": "^5.2.2",
    "vite": "^7.2.2",
    "vue-tsc": "^2.0.6"
  }
